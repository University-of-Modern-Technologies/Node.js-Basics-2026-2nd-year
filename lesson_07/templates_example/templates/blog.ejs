<main role="main" class="container">
  <div class="row">
    <div class="col-md-8 blog-main">
      <% posts.forEach(post => { %>
      <div class="blog-post">
        <h2 class="blog-post-title"><%= post.title %></h2>
        <p class="blog-post-meta">
          <%= post.date %> by <a href="#"><%= post.author %></a>
        </p>
        <p><%= post.body %></p>
      </div>
      <% }) %>
    </div>
  </div>
</main>
