<!DOCTYPE html>
<html lang="uk">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@picocss/pico@2/css/pico.min.css">
</head>
<body>
  <main class="container" style="max-width: 600px;">
    <h1><%= title %></h1>
    <p>Завантажено <strong><%= files.length %></strong> файлів:</p>
    <table>
      <thead>
        <tr>
          <th>originalname</th>
          <th>filename</th>
          <th>size</th>
        </tr>
      </thead>
      <tbody>
        <% files.forEach(f => { %>
        <tr>
          <td><%= f.originalname %></td>
          <td><%= f.filename %></td>
          <td><%= f.size %> байт</td>
        </tr>
        <% }) %>
      </tbody>
    </table>
    <a href="<%= back %>">← Назад</a>
  </main>
</body>
</html>
