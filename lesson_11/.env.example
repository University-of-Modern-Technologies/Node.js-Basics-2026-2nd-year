# Скопіюй у .env і підлаштуй за потреби:
#   copy .env.example .env   (Windows)
#   cp .env.example .env     (Unix)

DATABASE_URL="file:./dev.db"

# JWT secret — мінімум 256 біт для HS256
JWT_SECRET="your-secret-key-at-least-256-bits-long-for-development-only"

# Необов'язково: за замовчуванням у app.js порт 3000
# PORT=3000

# Для production cookie secure=true
# NODE_ENV=production
